# ============================================================
#  FRAGROUTE .gitignore
#  CRITICAL: never commit the private signing key, customer
#  data, the giant models, or the runtime binaries.
# ============================================================

# --- SECRETS: the license signing key (forges admin keys if leaked) ---
keys/
*.pem
*_private*
mint_license_out*.txt

# --- AI models (huge; distributed via the in-app Setup installer) ---
*.gguf
*.safetensors
*.ckpt
*.pth
*.onnx
*.bin
!fragpunk_taxonomy.txt

# --- runtime binary engines (shipped in the release bundle, not git) ---
llm/
sd/
stt/
yolo/
clip/
geo/
tts/
*.mmdb
ffmpeg.exe
wireguard.exe
*.zip

# --- build + release artifacts ---
dist/
build/
release/
__pycache__/
*.pyc
*.spec
assets/fragroute.ico
assets/fragroute.png

# --- the developer's / customers' PERSONAL data (never ship) ---
configs/
fragroute_queue_log.json
fragroute_settings.json
fragroute_servers.json
fragroute_serverpings.json
fragroute_players.json
fragroute_rank.json
fragroute_replays.json
fragroute_weapon_skins.json
fragroute_icons.json
fragroute_generated/
fragroute_captures/
fragroute_maps/
fragroute_diag.log
*.log
dataset/

# --- accounts + license state (per-machine; not source) ---
fragroute_accounts.json
fragroute_license.json
fragroute_throttle.json
.fragroute_trial

# --- local knowledge base (internal dev docs; not for the public repo) ---
# The Obsidian vault + the graphify code-graph. Regenerate the graph with update_knowledge.bat;
# see vault/Keeping this current.md. Remove these two lines if you WANT them version-controlled.
vault/
.obsidian/
graphify-out/

# --- editor / OS noise ---
.vscode/
.idea/
*.tmp
*.part
Thumbs.db
.DS_Store
fragroute_ui.BROKEN-17.6.html.bak
fragroute_skins_catalog.json
notes_20.txt
fragroute_lancer_catalog.json

# demo video build artifacts (heavy; regenerate with demo_make.py)
Fragnetic-demo.mp4
demo_frames/
headless_tour.log
Fragnetic-demo-v2.mp4
Fragnetic-demo-discord.mp4
demo_web.mp4
demo_take/
make_highlight.py
assemble_demo.py
demo_make.py
ship_assets/
release/
fragroute_persona.json
notes_20_*.txt
